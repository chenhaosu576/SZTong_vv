# 运行时
PORT=8080
NODE_ENV=development

# AI 代理
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=
BAIDU_MAP_AK=

# JWT（P0-2 用，先列上以便 .env 跟进）
JWT_SECRET=please_change_me
JWT_EXPIRES_IN=7d

# DB（P0 起生效，连接 MySQL 实例）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=sztong
DB_USER=root
DB_PASS=changeme                  # 模板占位符；本地 cp 为 .env 后改为实际值

# Sequelize 调优
DB_DIALECT=mysql
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_LOGGING=false                  # 调试 SQL 时改为 true
DB_TIMEZONE=+08:00
